# Test case (d2): unset root_type (treated as rootReference for backward compatibility)
query I
SELECT * FROM from_substrait_json('{
  "version": {
    "minorNumber": 19,
    "producer": "DuckDB"
  },
  "relations": [{
    "root": {
      "input": {
        "read": {
          "baseSchema": {
            "names": ["id"],
            "struct": {
              "types": [
                {"i32": {"nullability": "NULLABILITY_REQUIRED"}}
              ],
              "nullability": "NULLABILITY_REQUIRED"
            }
          },
          "namedTable": {"names": ["t1"]}
        }
      },
      "names": ["id"]
    }
  }]
}')
----
1
2

