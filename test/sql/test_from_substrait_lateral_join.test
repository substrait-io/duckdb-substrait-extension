              ],
              "outputType": {"bool": {"nullability": "NULLABILITY_REQUIRED"}}
            }
          },
          "postJoinFilter": {
            "scalarFunction": {
              "functionReference": 2,
              "arguments": [
                {"value": {"selection": {"directReference": {"structField": {"field": 3}}, "rootReference": {}}}},
                {"value": {"literal": {"i32": 150, "nullable": false}}}
              ],
              "outputType": {"bool": {"nullability": "NULLABILITY_REQUIRED"}}
            }
          },
          "type": "JOIN_TYPE_INNER"
