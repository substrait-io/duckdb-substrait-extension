# name: test/sql/test_not_equal_join.test
# description: Test not equal join comparison
# group: [substrait]

require substrait

statement ok
CREATE TABLE t1 (a INTEGER, b VARCHAR);

statement ok
INSERT INTO t1 VALUES (1, 'x'), (2, 'y'), (3, 'z');

statement ok
CREATE TABLE t2 (c INTEGER, d VARCHAR);

statement ok
INSERT INTO t2 VALUES (1, 'a'), (2, 'y'), (3, 'c');

# Test not equal join
statement ok
CALL get_substrait('SELECT t1.a, t1.b, t2.c, t2.d FROM t1, t2 WHERE t1.b <> t2.d');

statement ok
DROP TABLE t1;

statement ok
DROP TABLE t2;